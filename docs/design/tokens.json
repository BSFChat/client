{
  "$meta": {
    "source": "BSFChat.html",
    "note": "Canonical design tokens with dark (default) and light themes. Hex values are sRGB approximations of the authoritative oklch() values; prefer hex when your Qt build is < 6.6. Accent is parameterized by hue and is the SAME across themes — 180 is the default.",
    "accent": {
      "formula": "oklch(<L>% 0.17 <hue>)",
      "defaultHue": 180,
      "presetHues": { "cyan": 180, "violet": 260, "magenta": 320, "amber": 30 },
      "note": "Light-mode accent drops lightness to 60% for AA contrast on light surfaces."
    }
  },

  "themes": {
    "dark": {
      "surface": {
        "bg0":      { "oklch": "oklch(16% 0.008 260)",       "hex": "#16171b" },
        "bg1":      { "oklch": "oklch(19% 0.008 260)",       "hex": "#1c1d22" },
        "bg2":      { "oklch": "oklch(22% 0.009 260)",       "hex": "#222329" },
        "bg3":      { "oklch": "oklch(26% 0.010 260)",       "hex": "#2a2b32" },
        "bg4":      { "oklch": "oklch(30% 0.012 260)",       "hex": "#32333c" },
        "line":     { "oklch": "oklch(30% 0.010 260 / 0.6)", "hex": "#32333c99" },
        "lineSoft": { "oklch": "oklch(30% 0.010 260 / 0.3)", "hex": "#32333c4d" }
      },
      "text": {
        "fg0": { "oklch": "oklch(97% 0.005 260)", "hex": "#f5f5f7" },
        "fg1": { "oklch": "oklch(82% 0.008 260)", "hex": "#c8c9ce" },
        "fg2": { "oklch": "oklch(62% 0.010 260)", "hex": "#8e8f97" },
        "fg3": { "oklch": "oklch(48% 0.010 260)", "hex": "#6a6b73" },
        "fg4": { "oklch": "oklch(38% 0.008 260)", "hex": "#50515a" }
      },
      "accent": {
        "accent":     { "oklch": "oklch(78% 0.17 180)",        "hex": "#36d6c7" },
        "accentDim":  { "oklch": "oklch(65% 0.15 180)",        "hex": "#1fa89c" },
        "accentGlow": { "oklch": "oklch(78% 0.17 180 / 0.25)", "hex": "#36d6c740" }
      },
      "onAccent": { "hex": "#0a0a0a", "role": "text/glyph color ON accent surfaces (primary buttons, pills, speaking bars)" },
      "state": {
        "danger":  { "oklch": "oklch(68% 0.20 25)",  "hex": "#f04a5a" },
        "warn":    { "oklch": "oklch(82% 0.14 85)",  "hex": "#e7c156" },
        "online":  { "oklch": "oklch(75% 0.17 150)", "hex": "#2ecb8a" },
        "idle":    { "oklch": "oklch(78% 0.14 85)",  "hex": "#d9b64f" },
        "dnd":     { "oklch": "oklch(68% 0.20 25)",  "hex": "#f04a5a" },
        "offline": { "oklch": "oklch(50% 0.01 260)", "hex": "#73747c" }
      },
      "shadow": {
        "$note": "CSS strings + equivalent numeric tokens for MultiEffect. Feed numeric.* straight into MultiEffect { shadowColor; shadowBlur; shadowVerticalOffset; shadowOpacity }.",
        "color": "#000000",
        "css":   { "s1": "0 1px 2px rgba(0,0,0,0.30)", "s2": "0 4px 16px rgba(0,0,0,0.40)", "s3": "0 12px 48px rgba(0,0,0,0.55)" },
        "numeric": {
          "s1": { "blur": 0.08, "offsetY": 1,  "opacity": 0.30 },
          "s2": { "blur": 0.32, "offsetY": 4,  "opacity": 0.40 },
          "s3": { "blur": 0.80, "offsetY": 12, "opacity": 0.55 }
        }
      }
    },

    "light": {
      "$note": "Warm off-white surfaces (not pure white) to match the warm near-black dark palette. Hues match (260). Each surface step is ~3% L; text steps mirror the dark scale in reverse. Accent lightness drops so glyphs on light surfaces hit AA.",
      "surface": {
        "bg0":      { "oklch": "oklch(97% 0.004 260)",         "hex": "#f4f4f6", "role": "window bg — softest paper, not pure white" },
        "bg1":      { "oklch": "oklch(99.2% 0.003 260)",       "hex": "#fbfbfc", "role": "panels — slightly lighter than bg0 (inverted contrast vs dark)" },
        "bg2":      { "oklch": "oklch(94.5% 0.004 260)",       "hex": "#ededf0", "role": "elevated panels — subtly deeper than bg0" },
        "bg3":      { "oklch": "oklch(91% 0.005 260)",         "hex": "#e2e2e7", "role": "hover" },
        "bg4":      { "oklch": "oklch(86% 0.006 260)",         "hex": "#d3d4da", "role": "active / pressed" },
        "line":     { "oklch": "oklch(70% 0.008 260 / 0.28)",  "hex": "#a8a9b247", "role": "standard divider" },
        "lineSoft": { "oklch": "oklch(70% 0.008 260 / 0.14)",  "hex": "#a8a9b224", "role": "whisper divider" }
      },
      "text": {
        "fg0": { "oklch": "oklch(18% 0.010 260)", "hex": "#1a1b20", "role": "primary — near-black on paper" },
        "fg1": { "oklch": "oklch(32% 0.012 260)", "hex": "#3a3b44", "role": "secondary" },
        "fg2": { "oklch": "oklch(48% 0.010 260)", "hex": "#6a6b73", "role": "tertiary" },
        "fg3": { "oklch": "oklch(62% 0.008 260)", "hex": "#8f9099", "role": "muted" },
        "fg4": { "oklch": "oklch(74% 0.006 260)", "hex": "#b1b2b9", "role": "disabled" }
      },
      "accent": {
        "$note": "Drop L from 78% → 60% so accent text on bg1 passes AA; glow alpha stays the same.",
        "accent":     { "oklch": "oklch(60% 0.15 180)",        "hex": "#1d9991" },
        "accentDim":  { "oklch": "oklch(72% 0.13 180)",        "hex": "#4cbeb4" },
        "accentGlow": { "oklch": "oklch(60% 0.15 180 / 0.22)", "hex": "#1d999138" }
      },
      "onAccent": { "hex": "#ffffff", "role": "text/glyph color ON accent surfaces — white on the lower-L light-mode accent" },
      "state": {
        "$note": "Reds/greens pulled down in L to stay legible on light surfaces; chroma slightly reduced so they don't vibrate.",
        "danger":  { "oklch": "oklch(54% 0.22 25)",  "hex": "#d23040" },
        "warn":    { "oklch": "oklch(62% 0.14 70)",  "hex": "#b8842a" },
        "online":  { "oklch": "oklch(58% 0.17 150)", "hex": "#1e9862" },
        "idle":    { "oklch": "oklch(62% 0.14 70)",  "hex": "#b8842a" },
        "dnd":     { "oklch": "oklch(54% 0.22 25)",  "hex": "#d23040" },
        "offline": { "oklch": "oklch(70% 0.01 260)", "hex": "#aeafb6" }
      },
      "shadow": {
        "$note": "Softer, bluer shadows — pure black looks grubby on paper. CSS strings + numeric tokens for MultiEffect.",
        "color": "#141628",
        "css":   { "s1": "0 1px 2px rgba(20, 22, 40, 0.06)", "s2": "0 4px 16px rgba(20, 22, 40, 0.08)", "s3": "0 12px 48px rgba(20, 22, 40, 0.12)" },
        "numeric": {
          "s1": { "blur": 0.08, "offsetY": 1,  "opacity": 0.06 },
          "s2": { "blur": 0.32, "offsetY": 4,  "opacity": 0.08 },
          "s3": { "blur": 0.80, "offsetY": 12, "opacity": 0.12 }
        }
      }
    }
  },

  "font": {
    "sans": { "family": "Geist",      "fallback": "-apple-system, 'SF Pro Text', sans-serif" },
    "mono": { "family": "Geist Mono", "fallback": "ui-monospace, 'SF Mono', Menlo, monospace" },
    "size": {
      "xs":   11,
      "sm":   12,
      "base": 13,
      "md":   14,
      "lg":   16,
      "xl":   20,
      "xxl":  24,
      "title":32
    },
    "weight":       { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "letterSpacing":{ "tightest": "-0.03em", "tight": "-0.02em", "normal": "0", "wide": "0.08em", "widest": "0.12em" }
  },

  "radius": { "r1": 6, "r2": 10, "r3": 14, "r4": 18, "r5": 24, "pill": 9999 },

  "space": { "s1": 4, "s2": 6, "s3": 8, "s4": 10, "s5": 12, "s6": 14, "s7": 16, "s8": 20, "s9": 24, "s10": 32, "s11": 40, "s12": 56 },

  "motion": {
    "$note": "Easing is the exact cubic-bezier(0.2,0,0,1). In QML use Easing.BezierSpline with bezierCurve: [0.2, 0, 0, 1, 1, 1].",
    "fast":   { "ms": 120, "easing": "cubic-bezier(0.2,0,0,1)", "bezier": [0.2, 0, 0, 1] },
    "normal": { "ms": 180, "easing": "cubic-bezier(0.2,0,0,1)", "bezier": [0.2, 0, 0, 1] },
    "slow":   { "ms": 280, "easing": "cubic-bezier(0.2,0,0,1)", "bezier": [0.2, 0, 0, 1] },
    "speakingRingPulseMs": 900
  },

  "layout": {
    "$note": "Three density variants. 'standard' is the default; 'compact' narrows rails + tiles; 'focus' hides chat + member list for a voice/screen-share-only view. Mirror with Theme.variant in Theme.qml.",
    "appMinSize": { "w": 1280, "h": 800 },
    "avatarSize": { "sm": 24, "md": 32, "lg": 40, "xl": 80, "xxl": 132 },
    "variants": {
      "standard": {
        "serverRailW":      72,
        "channelSidebarW":  240,
        "chatPanelW":       320,
        "memberListW":      220,
        "voiceDockH":       64,
        "titleBarH":        40,
        "participantTile":  { "w": 220, "h": 180, "gap": 12, "radius": 14 },
        "dmListW":          280,
        "showChat":         true,
        "showMembers":      true
      },
      "compact": {
        "serverRailW":      60,
        "channelSidebarW":  200,
        "chatPanelW":       280,
        "memberListW":      180,
        "voiceDockH":       56,
        "titleBarH":        40,
        "participantTile":  { "w": 180, "h": 140, "gap": 10, "radius": 12 },
        "dmListW":          240,
        "showChat":         true,
        "showMembers":      true
      },
      "focus": {
        "serverRailW":      72,
        "channelSidebarW":  240,
        "chatPanelW":       0,
        "memberListW":      0,
        "voiceDockH":       64,
        "titleBarH":        40,
        "participantTile":  { "w": 260, "h": 200, "gap": 14, "radius": 14 },
        "dmListW":          280,
        "showChat":         false,
        "showMembers":      false
      }
    }
  }
}
